# RiskKernel configuration — copy to .env and fill in.
# Secrets are read from here or the real environment; the real environment wins.
# .env is gitignored. Keys are never stored in state, never logged.

# Daemon
RISKKERNEL_PORT=7070
RISKKERNEL_DATA_DIR=./data

# Single-tenant bearer token guarding the API. Leave empty for local-only use.
RISKKERNEL_API_TOKEN=

# Default provider for requests that don't specify one.
RISKKERNEL_DEFAULT_PROVIDER=anthropic

# Provider keys (native: anthropic). BYO key — used only for outbound calls.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
